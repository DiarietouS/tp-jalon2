# Exemple de configuration pour la production
# Copier ce fichier en .env et ajuster les valeurs
# Ne jamais committer le fichier .env dans le contrôle de version

# Base de données PostgreSQL
POSTGRES_DB=restaurants
POSTGRES_USER=postgres
POSTGRES_PASSWORD=votre_mot_de_passe_securise

# Clé secrète JWT (minimum 256 bits = 32 caractères)
JWT_SECRET=votre-cle-secrete-jwt-tres-longue-et-securisee

# Durée d'expiration du JWT en millisecondes (86400000 = 24 heures)
JWT_EXPIRATION=86400000
